rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /groups/{groupId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, create: if request.auth != null;
        // صاحب الرسالة بس يقدر يعدّلها (نص + edited) أو يحذفها حذف ناعم (text/deleted/file*)
        allow update: if request.auth != null &&
          request.auth.uid == resource.data.senderId &&
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(["text", "edited"]) ||
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(["text", "deleted", "fileUrl", "fileName", "fileType"])
          );
        allow delete: if false;
      }
      match /reads/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // NEW: الجروبات المخصصة (اللي المستخدم بيعملها بنفسه ويختار أعضاءها)
    match /custom_groups/{groupId} {
      allow read, update: if request.auth != null &&
        request.auth.uid in resource.data.memberIds;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.memberIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/custom_groups/$(groupId)).data.memberIds;
        allow create: if request.auth != null &&
          request.auth.uid == request.resource.data.senderId &&
          request.auth.uid in get(/databases/$(database)/documents/custom_groups/$(groupId)).data.memberIds;
        // صاحب الرسالة بس يقدر يعدّلها أو يحذفها حذف ناعم
        allow update: if request.auth != null &&
          request.auth.uid == resource.data.senderId &&
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(["text", "edited"]) ||
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(["text", "deleted", "fileUrl", "fileName", "fileType"])
          );
        allow delete: if false;
      }

      match /reads/{uid} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/custom_groups/$(groupId)).data.memberIds;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /chats/{chatId} {
      allow read, write: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if request.auth != null &&
          request.auth.uid == request.resource.data.senderId &&
          request.resource.data.senderId in
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.receiverId in
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow delete: if false;
        allow update: if request.auth != null && (
          // المستقبل بس يقدر يعلّم الرسالة إنها اتقرت
          (request.auth.uid == resource.data.receiverId &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(["seen"])) ||
          // صاحب الرسالة بس يقدر يعدّل نصها
          (request.auth.uid == resource.data.senderId &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(["text", "edited"])) ||
          // صاحب الرسالة بس يقدر يحذفها حذف ناعم
          (request.auth.uid == resource.data.senderId &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(["text", "deleted", "fileUrl", "fileName", "fileType"]))
        );
      }
    }
  }
}

