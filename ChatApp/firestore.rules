rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // بيانات المستخدمين: أي حد لوجن يقدر يقراها (عشان تظهر في قائمة اليوزرز)
    // لكن محدش يقدر يعدل غير بيانات نفسه
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // الجروب العام: أي يوزر مسجل دخول يقدر يقرا ويبعت فيه
    // (لازم تبقى top-level collection زي ما الكود بيستخدمها: db.collection("groups"))
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, create: if request.auth != null;
        allow update, delete: if false;
      }
    }

    // الشاتات والرسائل: يسمح بالقراءة/الكتابة فقط للطرفين المشاركين في المحادثة
    match /chats/{chatId} {
      allow read, write: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      // عند إنشاء مستند الشات لأول مرة (create) مفيش resource.data لسه
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if request.auth != null &&
          request.auth.uid == request.resource.data.senderId &&
          request.resource.data.senderId in
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.receiverId in
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        // مفيش مسح للرسائل، والتعديل مسموح بس لحقل "seen" وبس من المستلم
        allow delete: if false;
        allow update: if request.auth != null &&
          request.auth.uid == resource.data.receiverId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["seen"]);
      }
    }
  }
}
